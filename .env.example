# ── AI Provider ───────────────────────────────────────────────────────────────
# Pick ONE. The app checks in this order: OpenAI → Groq → Ollama → fallback.
# Without any key, briefs still generate (deterministic, no AI text).

# Option 1: OpenAI (paid — $5 tops for heavy use)
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini        # optional, this is the default

# Option 2: Groq — FREE tier, very fast, no credit card needed
# Sign up at https://console.groq.com → API Keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-8b-instant  # optional, this is the default

# Option 3: Ollama — fully local, free forever, no internet needed after setup
# 1. Install: https://ollama.com/download
# 2. Pull chat model:    ollama pull qwen2.5:7b     (~4.7GB, best JSON output)
# 3. Pull embed model:   ollama pull nomic-embed-text  (~274MB, fast semantic search)
# 4. Ollama starts automatically at http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_EMBED_MODEL=nomic-embed-text   # optional, this is the default
# OLLAMA_BASE_URL=http://localhost:11434 # optional, only if non-default port

# ── Storage ───────────────────────────────────────────────────────────────────
# Override the SQLite data directory (useful for Docker / Railway volumes)
# DATA_DIR=/app/data
